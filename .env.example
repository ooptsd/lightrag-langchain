# PostgreSQL (CONF-01)
LIGHTRAG_PG__HOST=localhost
LIGHTRAG_PG__PORT=5432
LIGHTRAG_PG__USER=your_username
LIGHTRAG_PG__PASSWORD=your_password
LIGHTRAG_PG__DATABASE=lightrag

# Optional — workspace isolation (default: "default")
LIGHTRAG_PG__WORKSPACE=default
# Optional — connection pool sizing (defaults shown)
LIGHTRAG_PG__POOL_MIN_SIZE=2
LIGHTRAG_PG__POOL_MAX_SIZE=10
# Optional — command timeout in seconds (default: 30)
LIGHTRAG_PG__POOL_TIMEOUT=30.0

# LLM (CONF-02)
LIGHTRAG_LLM__BINDING=openai
LIGHTRAG_LLM__BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_LLM__BINDING_API_KEY=sk-your-api-key
LIGHTRAG_LLM__MODEL=gpt-4o-mini
LIGHTRAG_LLM__TEMPERATURE=0.0
LIGHTRAG_LLM__MAX_TOKENS=9000

# Embedding (CONF-03)
LIGHTRAG_EMBEDDING__BINDING=openai
LIGHTRAG_EMBEDDING__BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_EMBEDDING__BINDING_API_KEY=sk-your-api-key
LIGHTRAG_EMBEDDING__MODEL=text-embedding-3-small
LIGHTRAG_EMBEDDING__DIM=1024

# Reranker (CONF-04, optional — leave empty to disable)
LIGHTRAG_RERANKER__BINDING=
LIGHTRAG_RERANKER__BINDING_HOST=
LIGHTRAG_RERANKER__BINDING_API_KEY=
LIGHTRAG_RERANKER__MODEL=
LIGHTRAG_RERANKER__MIN_RERANK_SCORE=0.0

# Query Parameters (CONF-05, defaults match upstream LightRAG)
LIGHTRAG_QUERY_PARAMS__TOP_K=40
LIGHTRAG_QUERY_PARAMS__CHUNK_TOP_K=20
LIGHTRAG_QUERY_PARAMS__MAX_ENTITY_TOKENS=6000
LIGHTRAG_QUERY_PARAMS__MAX_RELATION_TOKENS=8000
LIGHTRAG_QUERY_PARAMS__MAX_TOTAL_TOKENS=30000
LIGHTRAG_QUERY_PARAMS__COSINE_THRESHOLD=0.2
LIGHTRAG_QUERY_PARAMS__KG_CHUNK_PICK_METHOD=VECTOR

# Keyword Extraction (LLM-04, defaults shown)
LIGHTRAG_QUERY_PARAMS__KEYWORD_LANGUAGE=Chinese
